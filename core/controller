from __future__ import annotations

from dataclasses import dataclass


@dataclass
class PIDController:
    kp: float
    ki: float
    kd: float
    output_min: float = 0.0
    output_max: float = 100.0

    def __post_init__(self) -> None:
        self.integral = 0.0
        self.last_error = 0.0
        self.last_output = 0.0

    def reset(self) -> None:
        self.integral = 0.0
        self.last_error = 0.0
        self.last_output = 0.0

    def update(self, setpoint: float, measurement: float, dt: float) -> float:
        if dt <= 0:
            raise ValueError("dt must be greater than 0.")

        error = setpoint - measurement

        proportional = self.kp * error

        tentative_integral = self.integral + (error * dt)
        integral_term = self.ki * tentative_integral

        # derivative = (error - self.last_error) / dt
        # derivative_term = self.kd * derivative

        unclamped_output = proportional + integral_term
        # unclamped_output = proportional + integral_term + derivative_term

        clamped_output = max(self.output_min, min(unclamped_output, self.output_max))

        anti_windup_blocked = (
            (unclamped_output > self.output_max and error > 0)
            or (unclamped_output < self.output_min and error < 0)
        )

        if not anti_windup_blocked:
            self.integral = tentative_integral

        self.last_error = error
        self.last_output = clamped_output

        return clamped_output